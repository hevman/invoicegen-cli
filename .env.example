# ─────────────────────────────────────────────────────
#  invoice-cli — configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# Database: sqlite | postgresql | mysql | mssql
DB_CLIENT=sqlite
DB_FILENAME=./invoice.db

# PostgreSQL / MySQL / MSSQL (ignored when using sqlite)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=invoice_user
DB_PASSWORD=secret
DB_NAME=invoice_cli

# Your company / sender details (used on every invoice)
SENDER_NAME=Your Name
SENDER_EMAIL=you@example.com
SENDER_ADDRESS=123 Main St, City, Country
SENDER_TAX_ID=
SENDER_VAT_NUMBER=          # EU VAT number (e.g. DE123456789, leave empty for US)

# Path to system Chrome/Chromium (optional — uses bundled Chromium if not set)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_PATH=/usr/bin/google-chrome

# Default currency (USD, EUR, GBP, etc.)
DEFAULT_CURRENCY=USD

# Output directory for generated PDFs
OUTPUT_DIR=./invoices
